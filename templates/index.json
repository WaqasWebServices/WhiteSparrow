ch-text","blocks":{"heading":{"type":"heading","settings":{"title":"FARM TO FACE SKINCARE"}},"text":{"type":"text","settings":{"enlarge_text":false,"text":"\u003cp\u003eCreated with love at White Sparrow Farmacy. Our family has been turning to traditional methods these past few years and we are more than excited to share with you our tallow, returning to our roots and tradition steeped in our Pioneer Heritage. \u003c/p\u003e"}},"page_BWkEpV":{"type":"page","settings":{"page_text":"filligree-line"}}},"block_order":["heading","text","page_BWkEpV"],"settings":{"align_text":"center","narrow_column":true,"divider":false}},"slideshow_KbDcpq":{"type":"slideshow","blocks":{"image_D8UWre":{"type":"image","settings":{"top_subheading":"","title":"","title_size":80,"subheading":"","link":"","link_text":"Evening Heirloom Collection","link_2":"","link_text_2":"","color_accent":"#edeae0","text_align":"vertical-bottom horizontal-center","image":"shopify://shop_images/marielhannah-2026Products-14.jpg","parallax_direction":"top","overlay_opacity":8}},"image_YHAB44":{"type":"image","settings":{"top_subheading":"White Sparrow","title":"Restorative Face Tape","title_size":80,"subheading":"ADVANCED JAPANESE TECHNOLOGY","link":"shopify://products/restorative-face-tape","link_text":"EXPLORE","link_2":"shopify://products/restorative-face-tape","link_text_2":"","color_accent":"rgba(0,0,0,0)","text_align":"vertical-center horizontal-center","image":"shopify://shop_images/JapaneseFacetape.jpg","parallax_direction":"top","overlay_opacity":0}}},"block_order":["image_D8UWre","image_YHAB44"],"disabled":true,"name":"t:sections.slideshow.presets.hero_optional_slideshow.name","settings":{"section_height":"650px","mobile_height":"auto","parallax":false,"style":"dots","autoplay":true,"autoplay_speed":5,"lazyload_images":true}},"text_and_image_z6yFGD":{"type":"text-and-image","settings":{"image":"shopify://shop_images/marielhannah-2026Products-22.jpg","image_mask":"square","image2_mask":"none","subtitle":"","title":"WHY TALLOW?","text":"\u003cp\u003eIt is nature\u0027s perfect skin care product. Tallow supplies complete nutrition directly to the skin, resulting in optimal skin health, and includes vitamins A, D, E, K, B12 and more. The primary ingredient in our balm is tallow obtained from 100% grass fed cows. Tallow has been used as a healing skin care product since the beginning of time, even by our very own pioneer ancestors.\u003c/p\u003e","button_label":"Shop Now","button_link":"shopify://collections/all-products","button_style":"primary","align_text":"left","image_width":"50","layout":"right","divider":false,"top_padding":true,"bottom_padding":true,"lazyload_images":false}},"text_and_image_QCFgj3":{"type":"text-and-image","settings":{"image":"shopify://shop_images/marielhannah-2026Products-5.jpg","image_mask":"square","image2_mask":"square","subtitle":"","title":"100% NATURAL TALLOW","text":"\u003cp\u003eOur Tallow Balm is all natural, 100% organic, and is rendered from the fat of 100% grass fed cows. All of the ingredients come directly from nature with no added chemicals, preservatives, or additives. You can feel safe knowing that you are not putting anything foreign or synthetic on your body. All of our tallow is locally sourced from small farms right here in the USA. All of our products are handcrafted at our White Sparrow General Store from 1884 in Idaho.\u003c/p\u003e","button_label":"Shop Now","button_link":"shopify://collections/all-products","button_style":"primary","align_text":"left","image_width":"50","layout":"left","divider":false,"top_padding":true,"bottom_padding":true,"lazyload_images":true}},"promo_grid_NMEfAi":{"type":"promo-grid","blocks":{"advanced_k4GQfJ":{"type":"advanced","settings":{"subheading":"","heading":"","textarea":"","cta_text1":"SHOP FARMACY","cta_link1":"shopify://collections/tallow-balm-collection","cta_text2":"","cta_link2":"","image":"shopify://shop_images/Website-Pioneer_Pantry-2.png","video_url":"","width":"50","height":620,"text_size":100,"text_align":"vertical-center horizontal-center","color_accent":"#3e3e3e","boxed":false,"framed":false}},"advanced_yUDfKN":{"type":"advanced","settings":{"subheading":"","heading":"","textarea":"","cta_text1":"SHOP PIONEER PANTRY","cta_link1":"shopify://collections/pioneer-pantry","cta_text2":"","cta_link2":"","image":"shopify://shop_images/Website-Pioneer_Pantry-B.png","video_url":"","width":"50","height":420,"text_size":100,"text_align":"vertical-center horizontal-center","color_accent":"#3e3e3e","boxed":false,"framed":false}},"advanced_YcGKL7":{"type":"advanced","settings":{"subheading":"","heading":"","textarea":"","cta_text1":"SHOP NIGHTGOWNS","cta_link1":"shopify://collections/nightgown-collection","cta_text2":"","cta_link2":"","image":"shopify://shop_images/Website-Nightgowns2.png","video_url":"","width":"50","height":420,"text_size":100,"text_align":"vertical-center horizontal-center","color_accent":"#3e3e3e","boxed":false,"framed":false}}},"block_order":["advanced_k4GQfJ","advanced_yUDfKN","advanced_YcGKL7"],"name":"t:sections.promo-grid.presets.promotional_grid.name","settings":{"full_width":true,"gutter_size":0,"space_above":false,"space_below":false,"lazyload_images":false}},"featured_collections_3LYWHJ":{"type":"featured-collections","blocks":{"collection_nG6tjJ":{"type":"collection","settings":{"collection":"the-apothecarys-trio","title":"","focal_point":"center center"}},"collection_whbGQ6":{"type":"collection","settings":{"collection":"tallow-balm-collection","title":"","focal_point":"center center"}},"collection_DWNctL":{"type":"collection","settings":{"collection":"tallow-hair-oil","title":"","focal_point":"center center"}},"collection_cqjyLd":{"type":"collection","settings":{"collection":"sets","title":"","focal_point":"center center"}},"collection_Tcr7xX":{"type":"collection","settings":{"collection":"mens-tallow-line","title":"","focal_point":"center center"}}},"block_order":["collection_nG6tjJ","collection_whbGQ6","collection_DWNctL","collection_cqjyLd","collection_Tcr7xX"],"disabled":true,"name":"t:sections.featured-collections.presets.collection_list.name","settings":{"title":"Collection list","divider":false,"per_row":5,"enable_gutter":true}},"featured_collection_KG8WqW":{"type":"featured-collection","disabled":true,"name":"t:sections.featured-collection.presets.featured_collection.name","settings":{"title":"Featured collection","home_featured_products":"tallow-balm-collection","per_row":4,"rows":1,"mobile_scrollable":true,"view_all":true,"divider":false}},"text_and_image_FV7rCr":{"type":"text-and-image","name":"t:sections.text-and-image.presets.image_with_text.name","settings":{"image":"shopify://shop_images/1jamiefindlayphotographyidahocommercialphotography-48.jpg","image_mask":"portrait","image2_mask":"none","subtitle":"heritage nightgowns","title":"A dream kept for years","text":"\u003cp\u003eThis has been a dream of mine for years.\u003cbr/\u003eI’ve always longed to create heritage nightgowns - pieces that feel timeless, feminine, and deeply comforting. Garments meant for the quiet hours, for home, for rest. A dream kept close, waiting for the right moment.\u003c/p\u003e\u003cp\u003e\u003cbr/\u003eNow, that moment is here.\u003c/p\u003e\u003cp\u003e\u003cbr/\u003eEach nightgown is thoughtfully designed in the United States and carefully crafted by skilled artisans, made with intention and respect for the craft. These are pieces created to be lived in, loved, and kept - just as I always imagined.\u003c/p\u003e\u003cp\u003e\u003cbr/\u003e- Bree\u003c/p\u003e","button_label":"Available Now","button_link":"shopify://collections/nightgown-collection","button_style":"primary","align_text":"center","image_width":"50","layout":"right","divider":false,"top_padding":false,"bottom_padding":false,"lazyload_images":false}},"featured_collection_6p7gVq":{"type":"featured-collection","name":"t:sections.featured-collection.presets.featured_collection.name","settings":{"title":"HERITAGE NIGHTGOWN","home_featured_products":"nightgown-collection","per_row":3,"rows":1,"mobile_scrollable":true,"view_all":false,"divider":false}},"rich_text_rBpE6z":{"type":"rich-text","blocks":{"page_Qq9wRV":{"type":"page","settings":{"page_text":"filligree"}}},"block_order":["page_Qq9wRV"],"name":"t:sections.rich-text.presets.rich_text.name","settings":{"align_text":"center","narrow_column":true,"divider":false}},"background_image_text_mJJAwB":{"type":"background-image-text","disabled":true,"settings":{"subtitle":"","title":"","text":"\u003cp\u003eOriginated as a family-run endeavor in the Pacific Northwest, born from our quest to discover skincare products that were both natural and supremely beneficial. Over recent years, we\u0027ve embraced traditional methods, drawing inspiration from our rich Pioneer Heritage.\u003c/p\u003e","button_label":"","button_link":"","image":"shopify://shop_images/4-Website-WhiteSparrow-ManorEngraving-ProvincialBlue_copy.jpg","layout":"right","height":550,"framed":true,"parallax":false,"parallax_direction":"left","lazyload_images":false}},"blog_posts_FafT3A":{"type":"blog-posts","settings":{"title":"White Sparrow Journal","blog":"white-sparrow-farm","post_limit":3,"blog_show_tags":false,"blog_show_date":false,"blog_show_comments":false,"blog_show_author":false,"view_all":true,"blog_image_size":"wide","divider":false}},"cro_trust_bar":{"type":"cro-icon-grid","blocks":{"grass":{"type":"item","settings":{"marker":"GF","title":"100% Grass-Fed","text":""}},"farm":{"type":"item","settings":{"marker":"ID","title":"Family Farm, Idaho","text":""}},"stars":{"type":"item","settings":{"marker":"4.9","title":"4.9 Star Reviews","text":""}},"fillers":{"type":"item","settings":{"marker":"NO","title":"No Fillers, Ever","text":""}}},"block_order":["grass","farm","stars","fillers"],"settings":{"title":"","text":"","style":"compact","columns":"4","button_label":"","button_link":"","divider":false}},"cro_benefits":{"type":"cro-icon-grid","blocks":{"grass":{"type":"item","settings":{"marker":"GF","title":"Grass-Fed Tallow","text":"\u003cp\u003eSourced from 100% grass-fed cattle on our family farm in Idaho.\u003c/p\u003e"}},"fillers":{"type":"item","settings":{"marker":"NO","title":"No Fillers","text":"\u003cp\u003eEvery product is clean-label. No parabens, no synthetics, no ingredients you can\u0027t pronounce.\u003c/p\u003e"}},"farm":{"type":"item","settings":{"marker":"ID","title":"Family Farm","text":"\u003cp\u003eMade in small batches on the Mason family farm. Not outsourced. Not mass-produced.\u003c/p\u003e"}},"stars":{"type":"item","settings":{"marker":"4.9","title":"4.9 Stars","text":"\u003cp\u003eHundreds of verified reviews from real customers with real results.\u003c/p\u003e"}}},"block_order":["grass","fillers","farm","stars"],"settings":{"title":"","text":"","style":"standard","columns":"4","button_label":"","button_link":"","divider":false}},"homepage_faq":{"type":"faq","blocks":{"q1":{"type":"question","settings":{"title":"What is tallow balm and why is it good for skin?","text":"\u003cp\u003eBeef tallow is rendered fat from cattle. Grass-fed sourcing matters because it preserves a richer nutrient profile, and tallow\u0027s fatty acid profile makes it highly compatible with skin that needs concentrated moisture.\u003c/p\u003e"}},"q2":{"type":"question","settings":{"title":"Is tallow balm safe for sensitive skin and the face?","text":"\u003cp\u003eOur tallow balm is made without synthetic fragrance, parabens, or fillers. Many customers with eczema, rosacea, dry skin, and reactive skin find it gentler than conventional moisturizers.\u003c/p\u003e"}},"q3":{"type":"question","settings":{"title":"What\u0027s the difference between your Tallow Balm and a regular moisturizer?","text":"\u003cp\u003eMost regular moisturizers rely on water, emulsifiers, and synthetic preservatives. Tallow balm is concentrated, oil-based care made with ingredients your skin can actually use.\u003c/p\u003e"}},"q4":{"type":"question","settings":{"title":"Where does your tallow come from?","text":"\u003cp\u003eOur tallow comes from the Mason family farm in Idaho and is made in small batches for traceable, farm-sourced skincare.\u003c/p\u003e"}},"q5":{"type":"question","settings":{"title":"How long does one jar last?","text":"\u003cp\u003eMost customers get 2-3 months from a single jar. A little goes a long way because tallow balm is concentrated and not diluted with water.\u003c/p\u003e"}},"link":{"type":"rich-text","settings":{"title":"","text":"\u003cp\u003e\u003ca href=\"/pages/faq\"\u003eSee all FAQs\u003c/a\u003e\u003c/p\u003e","align_text":"center"}}},"block_order":["q1","q2","q3","q4","q5","link"],"settings":{"title":"Questions before you try tallow?"}}},"order":["hero_video_wABj7e","slideshow_YDrtqa","promo_grid_EeU6QY","rich_text_FqnRWM","rich_text_WwUKjE","cro_trust_bar","cro_benefits","featured-collection","featured_collection_dr4JQB","rich_text_LE6wVd","rich-text","slideshow_KbDcpq","text_and_image_z6yFGD","text_and_image_QCFgj3","promo_grid_NMEfAi","featured_collections_3LYWHJ","featured_collection_KG8WqW","text_and_image_FV7rCr","featured_collection_6p7gVq","rich_text_rBpE6z","background_image_text_mJJAwB","homepage_faq","blog_posts_FafT3A"]}